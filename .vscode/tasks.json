{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "detail": "Runs b.bat in a reusable integrated cmd terminal using the current VS Code environment.",
      "type": "shell",
      "command": "${workspaceFolder}\\b.bat",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "never",
        "revealProblems": "onProblem",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run",
      "detail": "Runs build\\main.exe in the integrated terminal.",
      "type": "shell",
      "command": "${workspaceFolder}\\build\\main.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    }
  ]
}
